# SkillCon Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
 
# JWT Secret — change this to a long random string in production
SKILLCON_JWT_SECRET=skillcon-secret-key-2024-very-long-CHANGE-IN-PROD
 
# Razorpay API Key — replace with your actual key
RAZORPAY_KEY=rzp_test_DEMO_KEY_REPLACE_ME
 